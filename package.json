{
  "name": "rainmatter-air-extension",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Chrome extension for the Rainmatter open-source air quality platform.",
  "scripts": {
    "check": "node scripts/validate.mjs && node --test test/*.test.mjs",
    "test": "node --test test/*.test.mjs",
    "test:live": "node scripts/test-live.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "package": "npm run check && node scripts/package.mjs"
  }
}
